# Iran-Israel Alert Monitor — Environment Variables
# Copy to .env and fill in your values

# Required
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Telegram channels (use @channelname or numeric chat ID)
TELEGRAM_CHAT_ID=@your-english-channel
TELEGRAM_CHAT_ID_HE=@your-hebrew-channel

# Optional: NordVPN Israel proxy (needed for Pikud HaOref from residential IPs outside Israel)
# Cloud/Azure IPs can reach Oref directly — proxy only needed for home/office networks
# NORD_USER=
# NORD_PASS=

# Optional: Generic HTTPS proxy with Israel IP (alternative to NordVPN)
# Any proxy service that exits through an Israeli IP works
# OREF_PROXY=https://user:pass@proxy-host:port

# Optional: NASA FIRMS fire detection API key (free at https://firms.modaps.eosdis.nasa.gov/api/area/)
# FIRMS_MAP_KEY=

# Optional: Azure API push endpoint
# API_URL=https://your-api.azurecontainerapps.io
# PUSH_API_KEY=

# Optional: Azure Table Storage (for DB backend)
# AZURE_TABLE_ENDPOINT=https://youraccount.table.core.windows.net
# AZURE_TABLE_NAME=intelevents

# Optional: timezone for display (default: Asia/Jerusalem)
# TIMEZONE=Asia/Jerusalem
